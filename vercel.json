{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "*.html",
          "*.js",
          "manifest.json",
          "sw.js",
          "package.json",
          "package-lock.json"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/index.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/run",
      "schedule": "0 0 * * *"
    }
  ]
}
